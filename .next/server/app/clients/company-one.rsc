a:["$","$L15",null,{"client":{"id":3,"slug":"company-one","name":"Company One","description":"Clean and trustworthy digital banking dashboard.","tags":["FINTECH","PRODUCT"],"accentColor":"#0055FF","column":"left","year":"2024","tagline":"Money, made simple.","brief":"A fintech startup with serious backers and a product that needed to earn trust in 3 seconds. We designed a banking dashboard that balanced data density with visual calm. Every number has a place. Every action has a clear path. The result launched to a 4.8 star rating on day one and has never dropped below it.","stat":"4.8*","statLabel":"App store rating maintained across 14 months post-launch","services":["Full Product Design (47 screens)","Design System (200+ components)","Data Visualisation Library","Onboarding Flow","Dark & Light Mode","Accessibility Audit (WCAG AA)"],"process":[{"number":"01","title":"Discovery","description":"We audited competitor dashboards, interviewed early investors, and studied where users hesitated when money felt risky."},{"number":"02","title":"Strategy","description":"The product vision centered on clarity under pressure: fewer decisions, stronger hierarchy, and confidence in every flow."},{"number":"03","title":"Design","description":"We built a polished interface system where charts, balances, and actions could coexist without visual fatigue."},{"number":"04","title":"Delivery","description":"A complete component library, responsive patterns, and QA standards shipped alongside the launch-ready product."}],"images":[{"src":"https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=800&q=80&auto=format&fit=crop","alt":"Financial chart screen representing Company One's trading dashboard."},{"src":"https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=800&q=80&auto=format&fit=crop","alt":"Credit card on a dark surface symbolizing secure fintech experiences."},{"src":"https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80&auto=format&fit=crop","alt":"Data dashboard shown on a laptop for the Company One case study."},{"src":"https://images.unsplash.com/photo-1559526324-4b87b5e36e44?w=800&q=80&auto=format&fit=crop","alt":"Person using a finance app on a smartphone."}],"metrics":[{"icon":"mobile","value":47,"label":"Screens designed end to end"},{"icon":"rating","value":4.8,"label":"App store rating at launch","decimals":1},{"icon":"system","value":200,"label":"Design system components"}],"testimonial":{"quote":"We had tried two other agencies before this. Nobody else understood that trust is a design problem. This team gets it at a level that is genuinely rare.","name":"Priya S.","role":"CPO, Company One"},"introStatement":"Trust is not copy. It is interface discipline made visible at every step.","introStat":{"value":"200+","label":"Reusable components shipped"},"briefHeading":"A banking dashboard that earns belief before the first tap.","briefParagraphs":["Company One was entering a crowded market with strong investors, serious product ambition, and a trust problem every fintech faces at launch. The experience had to look established before the brand actually was.","We focused on hierarchy, rhythm, and restraint. Every screen needed to feel exacting without becoming sterile. Dense information became readable through spacing, stronger grouping, and a component system designed around confidence.","The final product shipped with a visual language that felt both immediate and scalable. It helped the product team move faster internally while reassuring users that their money was in careful hands."],"servicesDetailed":[{"number":"01","title":"Product Design","description":"End-to-end flows for onboarding, account management, transfers, and investment touchpoints.","icon":"P"},{"number":"02","title":"Design System","description":"A disciplined component library built to keep data-heavy screens calm and consistent.","icon":"S"},{"number":"03","title":"Data Visualisation","description":"Charts and summaries tuned for speed of comprehension under real financial pressure.","icon":"D"},{"number":"04","title":"Onboarding Flow","description":"Trust-building first-run experience that reduces hesitation and accelerates completion.","icon":"O"},{"number":"05","title":"Theme Modes","description":"Dark and light presentation tuned for both premium feel and long-session usability.","icon":"T"},{"number":"06","title":"Accessibility QA","description":"Contrast, keyboard, and assistive-support standards baked in from system level upward.","icon":"A"}],"fullBleed":{"label":"Product Launch","quote":"The interface needed to feel proven on day one. That was the design brief in one sentence.","imageIndex":2},"imageStackCaption":"Product stills - launch cycle","imageStackIndex":"01 - 04","processHeading":"How trust became the interface.","photoGridLabel":"Data, product, precision","photoGridNote":"Each image supports the sense of clarity, confidence, and financial fluency behind the product."},"nextClient":{"id":4,"slug":"company-two","name":"Company Two","description":"Ultimate property discovery experience for modern buyers.","tags":["REAL ESTATE","UX"],"accentColor":"#2D6A4F","column":"right","year":"2024","tagline":"Find where you belong.","brief":"Property buyers in 2024 were doing everything on their phones but the platforms felt like they were built in 2009. We redesigned the entire discovery experience - from first search to signed offer. Filters that make sense. Maps that work. Listings that make you feel something. Drop-off fell 61% in the first quarter.","stat":"61%","statLabel":"reduction in search-to-enquiry drop-off rate after launch","services":["UX Research & Persona Development","Property Search & Filter System","Interactive Map Interface","Listing Detail Pages","Saved Homes & Comparison Tool","Agent Contact Flow"],"process":[{"number":"01","title":"Discovery","description":"We followed buyers through fragmented search journeys and identified exactly where outdated real-estate patterns were costing attention."},{"number":"02","title":"Strategy","description":"The new direction focused on calm decision-making: richer listing previews, better filters, and tighter map interactions."},{"number":"03","title":"Design","description":"Layouts, cards, and map components were tuned to feel aspirational without losing clarity or speed on mobile."},{"number":"04","title":"Delivery","description":"We delivered a modular search system, responsive listing flows, and a scalable visual language for future growth."}],"images":[{"src":"https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=80&auto=format&fit=crop","alt":"Luxury house exterior representing the Company Two property platform."},{"src":"https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=800&q=80&auto=format&fit=crop","alt":"Bright living room interior with premium styling."},{"src":"https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&q=80&auto=format&fit=crop","alt":"Modern architecture exterior used in the before and after comparison."},{"src":"https://images.unsplash.com/photo-1484154218962-a197022b5858?w=800&q=80&auto=format&fit=crop","alt":"Bright kitchen interior reflecting the aspirational housing experience."}],"metrics":[{"icon":"home","value":61,"label":"Drop-off reduction","suffix":"%"},{"icon":"search","value":12,"label":"Seconds average search to result"},{"icon":"location","value":4,"label":"Cities launched across"}],"testimonial":{"quote":"Our users were dropping off at the search stage. We thought it was a product problem. It was a design problem. Fixed in one sprint.","name":"Daniel W.","role":"CEO, Company Two"},"introStatement":"We turned property search from a chore into a calm, high-intent ritual.","introStat":{"value":"61%","label":"Search-to-enquiry drop-off reduced"},"briefHeading":"A real estate experience that sells the feeling, not just the floorplan.","briefParagraphs":["Company Two came to us with a familiar platform problem: users wanted to browse aspirational homes, but the product experience made that feel transactional, fragmented, and strangely exhausting.","We restructured the journey around emotional momentum. Search became simpler, filters became more human, and listings finally had space to create desire before demanding action. Maps, saved homes, and enquiry states all worked together instead of competing.","The result made buyers stay longer and act sooner. The platform felt premium without becoming precious, and practical without ever feeling cold."],"servicesDetailed":[{"number":"01","title":"Buyer Research","description":"Persona and journey work focused on where confidence disappeared in the property search flow.","icon":"R"},{"number":"02","title":"Search & Filters","description":"Criteria and sorting rebuilt around real decision habits, not legacy CMS constraints.","icon":"F"},{"number":"03","title":"Map Experience","description":"A more usable geographic layer that keeps search context visible while exploring listings.","icon":"M"},{"number":"04","title":"Listing Design","description":"Detail pages built to balance emotional imagery with practical next-step information.","icon":"L"},{"number":"05","title":"Saved Homes","description":"Comparison and revisit patterns designed for buyers making careful long-cycle decisions.","icon":"S"},{"number":"06","title":"Agent Contact Flow","description":"Enquiry states and forms streamlined to reduce hesitation at the moment of intent.","icon":"C"}],"fullBleed":{"label":"Premium discovery","quote":"Good real-estate UX makes the decision feel calmer before it makes it faster.","imageIndex":0},"imageStackCaption":"Location and lifestyle imagery","imageStackIndex":"01 - 04","processHeading":"How we rebuilt the search experience.","photoGridLabel":"Living inside the platform","photoGridNote":"Architecture, interiors, and the premium atmosphere that shaped every interaction choice."}}]
