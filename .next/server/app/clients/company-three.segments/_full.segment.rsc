a:["$","$L15",null,{"client":{"id":5,"slug":"company-three","name":"Company Three","description":"Simplifying patient journeys through thoughtful design.","tags":["HEALTHCARE","RESEARCH"],"accentColor":"#6B4EFF","column":"left","year":"2024","tagline":"Care, without the complexity.","brief":"Healthcare admin is quietly breaking people. Missed appointments. Lost referrals. Portals that require a computer science degree. We simplified everything - booking, records, communication - into one interface that patients actually want to use. Onboarding dropped from 14 minutes to under 4. Nobody cried in the waiting room anymore.","stat":"40%","statLabel":"faster patient onboarding, 14 minutes reduced to under 4","services":["Patient Journey Mapping","Booking & Scheduling UX","Records Access Interface","Accessibility QA","Notification Design System","Usability Testing"],"process":[{"number":"01","title":"Discovery","description":"We spoke with patients, care staff, and support teams to understand the quiet points of failure hidden inside the admin journey."},{"number":"02","title":"Strategy","description":"The product had to feel reassuring first and efficient second, with accessibility baked into the core interaction model."},{"number":"03","title":"Design","description":"We simplified flows, softened hierarchy, and used motion and spacing to reduce cognitive load across complex tasks."},{"number":"04","title":"Delivery","description":"The result shipped with reusable UI patterns, healthcare-safe messaging states, and a fully tested onboarding flow."}],"images":[{"src":"https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800&q=80&auto=format&fit=crop","alt":"Doctor using a tablet in a bright healthcare setting."},{"src":"https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=800&q=80&auto=format&fit=crop","alt":"Medical professional portrait used for the healthcare product story."},{"src":"https://images.unsplash.com/photo-1631217868264-e5b90bb7e133?w=800&q=80&auto=format&fit=crop","alt":"Healthcare app on a phone screen representing the patient interface."},{"src":"https://images.unsplash.com/photo-1530026405186-ed1f139313f8?w=800&q=80&auto=format&fit=crop","alt":"Calm wellness scene reinforcing the healthcare brand mood."}],"metrics":[{"icon":"health","value":40,"label":"Faster patient onboarding","suffix":"%"},{"icon":"form","value":6,"label":"Clicks to book an appointment"},{"icon":"accessibility","value":100,"label":"WCAG AA accessibility score","suffix":"%"}],"testimonial":{"quote":"Healthcare UX is hard because the stakes are real. This team treated it with the seriousness it deserved. Our patients noticed immediately.","name":"Dr. Ananya K.","role":"Head of Digital, Company Three"},"introStatement":"We reduced anxiety before we reduced clicks, and that changed everything.","introStat":{"value":"14 to 4","label":"Minutes trimmed from patient onboarding"},"briefHeading":"A healthcare product designed to feel calm before it feels clever.","briefParagraphs":["Healthcare journeys break when the interface ignores emotional context. Company Three needed to simplify booking, records, and communication, but the deeper challenge was helping patients feel supported while they used the system.","We designed the product around reassurance. Language softened. Priority states became clearer. Accessibility moved from a checklist to a design principle. Every flow was tuned to reduce cognitive load and create steadier momentum.","The final product did not just perform better. It felt better. That distinction mattered to patients, staff, and stakeholders in equal measure."],"servicesDetailed":[{"number":"01","title":"Journey Mapping","description":"Patient and staff pathways mapped end to end to expose hidden anxiety points in the service flow.","icon":"J"},{"number":"02","title":"Booking Experience","description":"Appointments redesigned around clarity, reassurance, and lower effort at each step.","icon":"B"},{"number":"03","title":"Records Access","description":"Health information structured to feel navigable and understandable without losing rigor.","icon":"R"},{"number":"04","title":"Accessibility QA","description":"Contrast, focus, semantics, and support patterns tested against real accessibility requirements.","icon":"A"},{"number":"05","title":"Notification Design","description":"Reminder and status systems designed to be calm, useful, and never alarming without reason.","icon":"N"},{"number":"06","title":"Usability Testing","description":"Iterative validation with staff and patients to tune the emotional feel as much as task speed.","icon":"U"}],"fullBleed":{"label":"Care journey","quote":"The best healthcare interfaces make people feel looked after before they even meet a person.","imageIndex":3},"imageStackCaption":"Care, clarity, and reassurance","imageStackIndex":"01 - 04","processHeading":"How we made care feel calmer.","photoGridLabel":"Moments of care","photoGridNote":"Bright clinical calm, human warmth, and tools designed to lower stress at every stage."},"nextClient":{"id":6,"slug":"company-four","name":"Company Four","description":"Learning platform built for momentum and daily progress.","tags":["PLATFORM","COURSES"],"accentColor":"#FF6B35","column":"right","year":"2025","tagline":"Learn without limits.","brief":"The client had one question: why do students pay for courses and never finish them? We spent a month finding out. The answer was mostly the interface - dull, rigid, and designed for administrators not learners. We rebuilt it around momentum. Small wins. Progress you can feel. Daily active usage doubled in three months.","stat":"2.1x","statLabel":"daily active usage increase within 3 months of relaunch","services":["Learning Platform UX","Course Card System","Progress Tracking Flows","Gamification Patterns","Brand Refresh","Content Design"],"process":[{"number":"01","title":"Discovery","description":"We watched how students dropped in and out of courses, where motivation broke, and what small rewards actually mattered."},{"number":"02","title":"Strategy","description":"The experience was reframed around momentum, visible progress, and a more human emotional reward system."},{"number":"03","title":"Design","description":"We designed brighter course flows, playful progress states, and a clearer hierarchy that made learning feel active."},{"number":"04","title":"Delivery","description":"A modular platform, brand toolkit, and engagement-focused UI shipped together to support future course growth."}],"images":[{"src":"https://images.unsplash.com/photo-1522202176988-66273c2fd55f?w=800&q=80&auto=format&fit=crop","alt":"Students collaborating around a table for the edtech case study."},{"src":"https://images.unsplash.com/photo-1501504905252-473c47e087f8?w=800&q=80&auto=format&fit=crop","alt":"Learner working on a laptop in a focused study environment."},{"src":"https://images.unsplash.com/photo-1427504494785-3a9ca7044f45?w=800&q=80&auto=format&fit=crop","alt":"Bright classroom scene showing collaborative learning."},{"src":"https://images.unsplash.com/photo-1488190211105-8b0e65b80b4e?w=800&q=80&auto=format&fit=crop","alt":"Study notes and desk setup with an energetic learning mood."}],"metrics":[{"icon":"books","value":94,"label":"Course completion rate","suffix":"%"},{"icon":"users","value":2.1,"label":"Daily active usage increase","suffix":"x","decimals":1},{"icon":"trophy","value":18,"label":"Awards won post-relaunch"}],"testimonial":{"quote":"We doubled daily active usage without changing a single feature. Just the design. That tells you everything you need to know.","name":"Liam O.","role":"Founder, Company Four"},"introStatement":"We rebuilt momentum into the product, so learning finally felt alive again.","introStat":{"value":"2.1x","label":"Daily active usage after relaunch"},"briefHeading":"A learning platform designed for progress you can actually feel.","briefParagraphs":["Company Four asked a brutally honest question: why were students paying for courses and then disappearing? The answer was not content quality. It was product energy - or rather, the lack of it.","We redesigned the platform around motivation. Progress became visible. Course architecture became lighter. Reward patterns, milestones, and content rhythm worked together to keep learners moving forward without turning the experience into a game for its own sake.","The relaunch proved the hypothesis quickly. Students returned more often, stayed longer, and completed more. The platform finally behaved like it wanted them to succeed."],"servicesDetailed":[{"number":"01","title":"Learning Experience UX","description":"Core course journeys rebuilt around attention, reward, and reduced drop-off.","icon":"L"},{"number":"02","title":"Course Card System","description":"A modular visual system that makes content variety feel exciting instead of overwhelming.","icon":"C"},{"number":"03","title":"Progress Tracking","description":"Milestones and momentum states designed to make advancement legible at a glance.","icon":"P"},{"number":"04","title":"Gamification Patterns","description":"Motivational interactions that support learning discipline without cheapening the product.","icon":"G"},{"number":"05","title":"Brand Refresh","description":"A brighter, bolder visual tone aligned with a more encouraging learning culture.","icon":"B"},{"number":"06","title":"Content Design","description":"Microcopy and structural guidance that keeps learners moving instead of second-guessing.","icon":"D"}],"fullBleed":{"label":"Learning momentum","quote":"The redesign did not just look better. It made students come back tomorrow.","imageIndex":0},"imageStackCaption":"Classroom energy and study rituals","imageStackIndex":"01 - 04","processHeading":"How we made learning stick.","photoGridLabel":"Motivation, visualized","photoGridNote":"Collaboration, study environments, and the emotional cues that keep a learner engaged."}}]
