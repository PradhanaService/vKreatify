0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"client":{"id":1,"slug":"noize","name":"Noize","description":"Bold brand identity and immersive e-commerce experience.","tags":["RETAIL","E-COMMERCE"],"accentColor":"#FF3B00","column":"left","year":"2023","tagline":"Where sound meets identity.","brief":"Noize came to us as a name on a napkin. A music collective that wanted to become a global apparel brand. We built everything from the ground up - the logo, the type system, the packaging language, the e-commerce platform, and the campaign motion pieces. The result is a brand that fans wear with pride and competitors study with envy.","stat":"3.2x","statLabel":"increase in online revenue within 6 months of launch","services":["Wordmark & Symbol Design","Full Brand Guidelines (120 page document)","Apparel Packaging System","E-commerce Platform (Shopify custom theme)","Campaign Motion Graphics","Social Media Design System"],"process":[{"number":"01","title":"Discovery","description":"Three weeks embedded with the Noize crew. Listening sessions, gig nights, wardrobe teardowns. Understanding what the culture actually is."},{"number":"02","title":"Strategy","description":"Brand positioning between streetwear and music label. The brand has to work on a vinyl sleeve and a hoodie equally."},{"number":"03","title":"Design","description":"47 logo concepts. 3 rounds of refinement. One final mark that the whole team tattooed - we are not joking."},{"number":"04","title":"Delivery","description":"Full Shopify build, motion package, brand guidelines, and a launch event visual identity."}],"images":[{"src":"https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?w=800&q=80&auto=format&fit=crop","alt":"Concert crowd moving under stage lights for the Noize launch campaign."},{"src":"https://images.unsplash.com/photo-1598387993441-a364f854c3e1?w=800&q=80&auto=format&fit=crop","alt":"Close-up vinyl record detail representing the tactile Noize identity."},{"src":"https://images.unsplash.com/photo-1511671782779-c97d3d27a1d4?w=800&q=80&auto=format&fit=crop","alt":"Music studio mixing board used as a reference for the Noize product system."},{"src":"https://images.unsplash.com/photo-1524368535928-5b5e00ddc76b?w=800&q=80&auto=format&fit=crop","alt":"Streetwear portrait showcasing the Noize apparel universe."}],"metrics":[{"icon":"music","value":320,"label":"Monthly active users (thousands)"},{"icon":"revenue","value":3.2,"label":"Revenue multiplier at launch","suffix":"x","decimals":1},{"icon":"rating","value":4.9,"label":"Average customer rating","decimals":1}],"testimonial":{"quote":"They did not just design our brand. They understood our culture, our people, and what we were trying to say to the world. The result is something we are genuinely proud of.","name":"Marcus T.","role":"Founder, Noize Collective"},"introStatement":"We took a name on a napkin and turned it into a brand that sells out in minutes.","introStat":{"value":"47","label":"Logo concepts explored"},"briefHeading":"A brand with no rules, built for people who make them.","briefParagraphs":["Noize came to us as a collective of musicians and creatives with a clear vision: build a brand that their community would wear with pride. Not just a logo. A movement. We spent three weeks embedded with the team - attending gigs, listening sessions, and visiting studios - before we touched a single design tool.","The strategy that emerged was simple: Noize should feel like it was made by the community, not for them. The visual language had to live equally on a vinyl sleeve, a hoodie, a phone screen, and a billboard. Every element had to earn its place.","What followed was 47 logo concepts, three rounds of refinement with the full Noize crew, and one final mark that the founding members reportedly tattooed on launch day. We will not confirm or deny."],"servicesDetailed":[{"number":"01","title":"Wordmark & Symbol Design","description":"A custom letterform system built to scale from 16px favicon to 10ft mural.","icon":"N"},{"number":"02","title":"Brand Guidelines","description":"120-page document covering voice, color, type, photography, and motion.","icon":"G"},{"number":"03","title":"Apparel Packaging","description":"Hangtags, boxes, tissue paper, and sticker sheets - all brand coherent.","icon":"P"},{"number":"04","title":"E-commerce Platform","description":"Custom Shopify theme built from brand system. Zero templates used.","icon":"W"},{"number":"05","title":"Campaign Motion","description":"Social-first motion graphics for launch campaign across four platforms.","icon":"M"},{"number":"06","title":"Design System","description":"Component library handed to the internal team for ongoing use.","icon":"D"}],"fullBleed":{"label":"Launch Campaign","quote":"The night we launched, we sold out in 4 minutes.","imageIndex":0},"imageStackCaption":"Project photography - 2023","imageStackIndex":"01 - 04","processHeading":"How we got there.","photoGridLabel":"More from the Noize universe","photoGridNote":"Streetwear texture, venue energy, and product atmosphere built into one visual system."},"nextClient":{"id":2,"slug":"tattoo-collective","name":"Tattoo Collective","description":"Seamless booking platform for modern tattoo studios.","tags":["BRANDING","WEB DESIGN"],"accentColor":"#C0392B","column":"right","year":"2019","tagline":"Art that lives on skin and screen.","brief":"Twenty four of the most sought-after tattoo artists in the country. One problem: no unified platform to book them. We designed a digital studio that respects the artistry, streamlines the admin, and lets the work speak. Artists build portfolios. Clients book sessions. Nobody fights with a Google Form anymore.","stat":"89%","statLabel":"booking completion rate, up from 34% on their previous system","services":["UX Research & Journey Mapping","Artist Portfolio System","Booking & Calendar Platform","Client Profile & History","Studio Brand Identity","Mobile-first Web App"],"process":[{"number":"01","title":"Discovery","description":"Artist interviews, studio shadowing, and mapping every call, DM, and booking request happening behind the scenes."},{"number":"02","title":"Strategy","description":"We framed the platform around artist craft first, with admin quietly disappearing into the background."},{"number":"03","title":"Design","description":"Portfolio storytelling, booking flows, and availability states were refined until the product felt as precise as the artists themselves."},{"number":"04","title":"Delivery","description":"Responsive web app, artist onboarding system, and a flexible identity that scales across studios and guest residencies."}],"images":[{"src":"https://images.unsplash.com/photo-1542856391-010fb87dcfed?w=800&q=80&auto=format&fit=crop","alt":"Tattoo artist working on a client in a studio setting."},{"src":"https://images.unsplash.com/photo-1612459284270-b6a7bd9e1330?w=800&q=80&auto=format&fit=crop","alt":"Detailed tattoo art close-up used for the Tattoo Collective showcase."},{"src":"https://images.unsplash.com/photo-1598300042247-d088f8ab3a91?w=800&q=80&auto=format&fit=crop","alt":"Tattoo studio interior with curated lighting and equipment."},{"src":"https://images.unsplash.com/photo-1568515045052-f9a854d70bfd?w=800&q=80&auto=format&fit=crop","alt":"Artistic arm tattoo portrait reflecting the studio aesthetic."}],"metrics":[{"icon":"art","value":24,"label":"Artists onboarded to platform"},{"icon":"calendar","value":89,"label":"Booking completion rate","suffix":"%"},{"icon":"time","value":3,"label":"Minutes average booking time"}],"testimonial":{"quote":"Our artists were skeptical about going digital. Within a week of launch, every single one of them was fully booked through the platform. It just works.","name":"Jade R.","role":"Studio Director, Tattoo Collective"},"introStatement":"We made the studio feel as personal online as it does in the chair.","introStat":{"value":"24","label":"Artists unified on one platform"},"briefHeading":"An online studio that respects the craft before the software.","briefParagraphs":["Tattoo Collective brought together twenty four sought-after artists, but the booking experience still depended on scattered DMs, email chains, and manually updated calendars. The work felt premium. The administration did not.","We treated the product like an extension of the studio itself: intimate, atmospheric, highly personal, and never louder than the art. Portfolio storytelling came first. Admin became invisible. Clients could finally browse, trust, and commit without friction.","The launch changed the studio rhythm immediately. Artists had clearer schedules, clients had confidence in the process, and the platform became a new part of the brand - not just a utility tucked behind it."],"servicesDetailed":[{"number":"01","title":"Research & Journey Mapping","description":"Mapped every friction point from discovery to confirmed session across artists and clients.","icon":"R"},{"number":"02","title":"Artist Portfolio System","description":"A modular showcase structure that lets each artist feel distinct without breaking cohesion.","icon":"A"},{"number":"03","title":"Booking Platform","description":"Availability, deposits, and scheduling designed to feel precise, not clinical.","icon":"B"},{"number":"04","title":"Client Profiles","description":"History, preferences, and references surfaced at the right moment for smoother bookings.","icon":"C"},{"number":"05","title":"Studio Identity","description":"A digital expression of the studio atmosphere, rooted in craft and quiet confidence.","icon":"I"},{"number":"06","title":"Mobile-first Web App","description":"Built for clients who discover an artist on social and book from their phone immediately.","icon":"M"}],"fullBleed":{"label":"Studio Atmosphere","quote":"The platform feels like the studio sounds: calm, focused, and unmistakably ours.","imageIndex":2},"imageStackCaption":"Studio documentation - Cape Town","imageStackIndex":"01 - 04","processHeading":"How we shaped the studio online.","photoGridLabel":"Inside the craft","photoGridNote":"Material detail, artist energy, and the quiet rituals around every appointment."}}],["$L3","$L4"],"$L5"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"tm1SaEzyKFRM92keFoSRS"}
