a:["$","$L15",null,{"client":{"id":4,"slug":"company-two","name":"Company Two","description":"Ultimate property discovery experience for modern buyers.","tags":["REAL ESTATE","UX"],"accentColor":"#2D6A4F","column":"right","year":"2024","tagline":"Find where you belong.","brief":"Property buyers in 2024 were doing everything on their phones but the platforms felt like they were built in 2009. We redesigned the entire discovery experience - from first search to signed offer. Filters that make sense. Maps that work. Listings that make you feel something. Drop-off fell 61% in the first quarter.","stat":"61%","statLabel":"reduction in search-to-enquiry drop-off rate after launch","services":["UX Research & Persona Development","Property Search & Filter System","Interactive Map Interface","Listing Detail Pages","Saved Homes & Comparison Tool","Agent Contact Flow"],"process":[{"number":"01","title":"Discovery","description":"We followed buyers through fragmented search journeys and identified exactly where outdated real-estate patterns were costing attention."},{"number":"02","title":"Strategy","description":"The new direction focused on calm decision-making: richer listing previews, better filters, and tighter map interactions."},{"number":"03","title":"Design","description":"Layouts, cards, and map components were tuned to feel aspirational without losing clarity or speed on mobile."},{"number":"04","title":"Delivery","description":"We delivered a modular search system, responsive listing flows, and a scalable visual language for future growth."}],"images":[{"src":"https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=800&q=80&auto=format&fit=crop","alt":"Luxury house exterior representing the Company Two property platform."},{"src":"https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=800&q=80&auto=format&fit=crop","alt":"Bright living room interior with premium styling."},{"src":"https://images.unsplash.com/photo-1512917774080-9991f1c4c750?w=800&q=80&auto=format&fit=crop","alt":"Modern architecture exterior used in the before and after comparison."},{"src":"https://images.unsplash.com/photo-1484154218962-a197022b5858?w=800&q=80&auto=format&fit=crop","alt":"Bright kitchen interior reflecting the aspirational housing experience."}],"metrics":[{"icon":"home","value":61,"label":"Drop-off reduction","suffix":"%"},{"icon":"search","value":12,"label":"Seconds average search to result"},{"icon":"location","value":4,"label":"Cities launched across"}],"testimonial":{"quote":"Our users were dropping off at the search stage. We thought it was a product problem. It was a design problem. Fixed in one sprint.","name":"Daniel W.","role":"CEO, Company Two"},"introStatement":"We turned property search from a chore into a calm, high-intent ritual.","introStat":{"value":"61%","label":"Search-to-enquiry drop-off reduced"},"briefHeading":"A real estate experience that sells the feeling, not just the floorplan.","briefParagraphs":["Company Two came to us with a familiar platform problem: users wanted to browse aspirational homes, but the product experience made that feel transactional, fragmented, and strangely exhausting.","We restructured the journey around emotional momentum. Search became simpler, filters became more human, and listings finally had space to create desire before demanding action. Maps, saved homes, and enquiry states all worked together instead of competing.","The result made buyers stay longer and act sooner. The platform felt premium without becoming precious, and practical without ever feeling cold."],"servicesDetailed":[{"number":"01","title":"Buyer Research","description":"Persona and journey work focused on where confidence disappeared in the property search flow.","icon":"R"},{"number":"02","title":"Search & Filters","description":"Criteria and sorting rebuilt around real decision habits, not legacy CMS constraints.","icon":"F"},{"number":"03","title":"Map Experience","description":"A more usable geographic layer that keeps search context visible while exploring listings.","icon":"M"},{"number":"04","title":"Listing Design","description":"Detail pages built to balance emotional imagery with practical next-step information.","icon":"L"},{"number":"05","title":"Saved Homes","description":"Comparison and revisit patterns designed for buyers making careful long-cycle decisions.","icon":"S"},{"number":"06","title":"Agent Contact Flow","description":"Enquiry states and forms streamlined to reduce hesitation at the moment of intent.","icon":"C"}],"fullBleed":{"label":"Premium discovery","quote":"Good real-estate UX makes the decision feel calmer before it makes it faster.","imageIndex":0},"imageStackCaption":"Location and lifestyle imagery","imageStackIndex":"01 - 04","processHeading":"How we rebuilt the search experience.","photoGridLabel":"Living inside the platform","photoGridNote":"Architecture, interiors, and the premium atmosphere that shaped every interaction choice."},"nextClient":{"id":5,"slug":"company-three","name":"Company Three","description":"Simplifying patient journeys through thoughtful design.","tags":["HEALTHCARE","RESEARCH"],"accentColor":"#6B4EFF","column":"left","year":"2024","tagline":"Care, without the complexity.","brief":"Healthcare admin is quietly breaking people. Missed appointments. Lost referrals. Portals that require a computer science degree. We simplified everything - booking, records, communication - into one interface that patients actually want to use. Onboarding dropped from 14 minutes to under 4. Nobody cried in the waiting room anymore.","stat":"40%","statLabel":"faster patient onboarding, 14 minutes reduced to under 4","services":["Patient Journey Mapping","Booking & Scheduling UX","Records Access Interface","Accessibility QA","Notification Design System","Usability Testing"],"process":[{"number":"01","title":"Discovery","description":"We spoke with patients, care staff, and support teams to understand the quiet points of failure hidden inside the admin journey."},{"number":"02","title":"Strategy","description":"The product had to feel reassuring first and efficient second, with accessibility baked into the core interaction model."},{"number":"03","title":"Design","description":"We simplified flows, softened hierarchy, and used motion and spacing to reduce cognitive load across complex tasks."},{"number":"04","title":"Delivery","description":"The result shipped with reusable UI patterns, healthcare-safe messaging states, and a fully tested onboarding flow."}],"images":[{"src":"https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?w=800&q=80&auto=format&fit=crop","alt":"Doctor using a tablet in a bright healthcare setting."},{"src":"https://images.unsplash.com/photo-1559757148-5c350d0d3c56?w=800&q=80&auto=format&fit=crop","alt":"Medical professional portrait used for the healthcare product story."},{"src":"https://images.unsplash.com/photo-1631217868264-e5b90bb7e133?w=800&q=80&auto=format&fit=crop","alt":"Healthcare app on a phone screen representing the patient interface."},{"src":"https://images.unsplash.com/photo-1530026405186-ed1f139313f8?w=800&q=80&auto=format&fit=crop","alt":"Calm wellness scene reinforcing the healthcare brand mood."}],"metrics":[{"icon":"health","value":40,"label":"Faster patient onboarding","suffix":"%"},{"icon":"form","value":6,"label":"Clicks to book an appointment"},{"icon":"accessibility","value":100,"label":"WCAG AA accessibility score","suffix":"%"}],"testimonial":{"quote":"Healthcare UX is hard because the stakes are real. This team treated it with the seriousness it deserved. Our patients noticed immediately.","name":"Dr. Ananya K.","role":"Head of Digital, Company Three"},"introStatement":"We reduced anxiety before we reduced clicks, and that changed everything.","introStat":{"value":"14 to 4","label":"Minutes trimmed from patient onboarding"},"briefHeading":"A healthcare product designed to feel calm before it feels clever.","briefParagraphs":["Healthcare journeys break when the interface ignores emotional context. Company Three needed to simplify booking, records, and communication, but the deeper challenge was helping patients feel supported while they used the system.","We designed the product around reassurance. Language softened. Priority states became clearer. Accessibility moved from a checklist to a design principle. Every flow was tuned to reduce cognitive load and create steadier momentum.","The final product did not just perform better. It felt better. That distinction mattered to patients, staff, and stakeholders in equal measure."],"servicesDetailed":[{"number":"01","title":"Journey Mapping","description":"Patient and staff pathways mapped end to end to expose hidden anxiety points in the service flow.","icon":"J"},{"number":"02","title":"Booking Experience","description":"Appointments redesigned around clarity, reassurance, and lower effort at each step.","icon":"B"},{"number":"03","title":"Records Access","description":"Health information structured to feel navigable and understandable without losing rigor.","icon":"R"},{"number":"04","title":"Accessibility QA","description":"Contrast, focus, semantics, and support patterns tested against real accessibility requirements.","icon":"A"},{"number":"05","title":"Notification Design","description":"Reminder and status systems designed to be calm, useful, and never alarming without reason.","icon":"N"},{"number":"06","title":"Usability Testing","description":"Iterative validation with staff and patients to tune the emotional feel as much as task speed.","icon":"U"}],"fullBleed":{"label":"Care journey","quote":"The best healthcare interfaces make people feel looked after before they even meet a person.","imageIndex":3},"imageStackCaption":"Care, clarity, and reassurance","imageStackIndex":"01 - 04","processHeading":"How we made care feel calmer.","photoGridLabel":"Moments of care","photoGridNote":"Bright clinical calm, human warmth, and tools designed to lower stress at every stage."}}]
