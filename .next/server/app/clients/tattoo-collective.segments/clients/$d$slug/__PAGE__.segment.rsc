0:{"rsc":["$","$1","c",{"children":[["$","$L2",null,{"client":{"id":2,"slug":"tattoo-collective","name":"Tattoo Collective","description":"Seamless booking platform for modern tattoo studios.","tags":["BRANDING","WEB DESIGN"],"accentColor":"#C0392B","column":"right","year":"2019","tagline":"Art that lives on skin and screen.","brief":"Twenty four of the most sought-after tattoo artists in the country. One problem: no unified platform to book them. We designed a digital studio that respects the artistry, streamlines the admin, and lets the work speak. Artists build portfolios. Clients book sessions. Nobody fights with a Google Form anymore.","stat":"89%","statLabel":"booking completion rate, up from 34% on their previous system","services":["UX Research & Journey Mapping","Artist Portfolio System","Booking & Calendar Platform","Client Profile & History","Studio Brand Identity","Mobile-first Web App"],"process":[{"number":"01","title":"Discovery","description":"Artist interviews, studio shadowing, and mapping every call, DM, and booking request happening behind the scenes."},{"number":"02","title":"Strategy","description":"We framed the platform around artist craft first, with admin quietly disappearing into the background."},{"number":"03","title":"Design","description":"Portfolio storytelling, booking flows, and availability states were refined until the product felt as precise as the artists themselves."},{"number":"04","title":"Delivery","description":"Responsive web app, artist onboarding system, and a flexible identity that scales across studios and guest residencies."}],"images":[{"src":"https://images.unsplash.com/photo-1542856391-010fb87dcfed?w=800&q=80&auto=format&fit=crop","alt":"Tattoo artist working on a client in a studio setting."},{"src":"https://images.unsplash.com/photo-1612459284270-b6a7bd9e1330?w=800&q=80&auto=format&fit=crop","alt":"Detailed tattoo art close-up used for the Tattoo Collective showcase."},{"src":"https://images.unsplash.com/photo-1598300042247-d088f8ab3a91?w=800&q=80&auto=format&fit=crop","alt":"Tattoo studio interior with curated lighting and equipment."},{"src":"https://images.unsplash.com/photo-1568515045052-f9a854d70bfd?w=800&q=80&auto=format&fit=crop","alt":"Artistic arm tattoo portrait reflecting the studio aesthetic."}],"metrics":[{"icon":"art","value":24,"label":"Artists onboarded to platform"},{"icon":"calendar","value":89,"label":"Booking completion rate","suffix":"%"},{"icon":"time","value":3,"label":"Minutes average booking time"}],"testimonial":{"quote":"Our artists were skeptical about going digital. Within a week of launch, every single one of them was fully booked through the platform. It just works.","name":"Jade R.","role":"Studio Director, Tattoo Collective"},"introStatement":"We made the studio feel as personal online as it does in the chair.","introStat":{"value":"24","label":"Artists unified on one platform"},"briefHeading":"An online studio that respects the craft before the software.","briefParagraphs":["Tattoo Collective brought together twenty four sought-after artists, but the booking experience still depended on scattered DMs, email chains, and manually updated calendars. The work felt premium. The administration did not.","We treated the product like an extension of the studio itself: intimate, atmospheric, highly personal, and never louder than the art. Portfolio storytelling came first. Admin became invisible. Clients could finally browse, trust, and commit without friction.","The launch changed the studio rhythm immediately. Artists had clearer schedules, clients had confidence in the process, and the platform became a new part of the brand - not just a utility tucked behind it."],"servicesDetailed":[{"number":"01","title":"Research & Journey Mapping","description":"Mapped every friction point from discovery to confirmed session across artists and clients.","icon":"R"},{"number":"02","title":"Artist Portfolio System","description":"A modular showcase structure that lets each artist feel distinct without breaking cohesion.","icon":"A"},{"number":"03","title":"Booking Platform","description":"Availability, deposits, and scheduling designed to feel precise, not clinical.","icon":"B"},{"number":"04","title":"Client Profiles","description":"History, preferences, and references surfaced at the right moment for smoother bookings.","icon":"C"},{"number":"05","title":"Studio Identity","description":"A digital expression of the studio atmosphere, rooted in craft and quiet confidence.","icon":"I"},{"number":"06","title":"Mobile-first Web App","description":"Built for clients who discover an artist on social and book from their phone immediately.","icon":"M"}],"fullBleed":{"label":"Studio Atmosphere","quote":"The platform feels like the studio sounds: calm, focused, and unmistakably ours.","imageIndex":2},"imageStackCaption":"Studio documentation - Cape Town","imageStackIndex":"01 - 04","processHeading":"How we shaped the studio online.","photoGridLabel":"Inside the craft","photoGridNote":"Material detail, artist energy, and the quiet rituals around every appointment."},"nextClient":{"id":3,"slug":"company-one","name":"Company One","description":"Clean and trustworthy digital banking dashboard.","tags":["FINTECH","PRODUCT"],"accentColor":"#0055FF","column":"left","year":"2024","tagline":"Money, made simple.","brief":"A fintech startup with serious backers and a product that needed to earn trust in 3 seconds. We designed a banking dashboard that balanced data density with visual calm. Every number has a place. Every action has a clear path. The result launched to a 4.8 star rating on day one and has never dropped below it.","stat":"4.8*","statLabel":"App store rating maintained across 14 months post-launch","services":["Full Product Design (47 screens)","Design System (200+ components)","Data Visualisation Library","Onboarding Flow","Dark & Light Mode","Accessibility Audit (WCAG AA)"],"process":[{"number":"01","title":"Discovery","description":"We audited competitor dashboards, interviewed early investors, and studied where users hesitated when money felt risky."},{"number":"02","title":"Strategy","description":"The product vision centered on clarity under pressure: fewer decisions, stronger hierarchy, and confidence in every flow."},{"number":"03","title":"Design","description":"We built a polished interface system where charts, balances, and actions could coexist without visual fatigue."},{"number":"04","title":"Delivery","description":"A complete component library, responsive patterns, and QA standards shipped alongside the launch-ready product."}],"images":[{"src":"https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?w=800&q=80&auto=format&fit=crop","alt":"Financial chart screen representing Company One's trading dashboard."},{"src":"https://images.unsplash.com/photo-1563013544-824ae1b704d3?w=800&q=80&auto=format&fit=crop","alt":"Credit card on a dark surface symbolizing secure fintech experiences."},{"src":"https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=800&q=80&auto=format&fit=crop","alt":"Data dashboard shown on a laptop for the Company One case study."},{"src":"https://images.unsplash.com/photo-1559526324-4b87b5e36e44?w=800&q=80&auto=format&fit=crop","alt":"Person using a finance app on a smartphone."}],"metrics":[{"icon":"mobile","value":47,"label":"Screens designed end to end"},{"icon":"rating","value":4.8,"label":"App store rating at launch","decimals":1},{"icon":"system","value":200,"label":"Design system components"}],"testimonial":{"quote":"We had tried two other agencies before this. Nobody else understood that trust is a design problem. This team gets it at a level that is genuinely rare.","name":"Priya S.","role":"CPO, Company One"},"introStatement":"Trust is not copy. It is interface discipline made visible at every step.","introStat":{"value":"200+","label":"Reusable components shipped"},"briefHeading":"A banking dashboard that earns belief before the first tap.","briefParagraphs":["Company One was entering a crowded market with strong investors, serious product ambition, and a trust problem every fintech faces at launch. The experience had to look established before the brand actually was.","We focused on hierarchy, rhythm, and restraint. Every screen needed to feel exacting without becoming sterile. Dense information became readable through spacing, stronger grouping, and a component system designed around confidence.","The final product shipped with a visual language that felt both immediate and scalable. It helped the product team move faster internally while reassuring users that their money was in careful hands."],"servicesDetailed":[{"number":"01","title":"Product Design","description":"End-to-end flows for onboarding, account management, transfers, and investment touchpoints.","icon":"P"},{"number":"02","title":"Design System","description":"A disciplined component library built to keep data-heavy screens calm and consistent.","icon":"S"},{"number":"03","title":"Data Visualisation","description":"Charts and summaries tuned for speed of comprehension under real financial pressure.","icon":"D"},{"number":"04","title":"Onboarding Flow","description":"Trust-building first-run experience that reduces hesitation and accelerates completion.","icon":"O"},{"number":"05","title":"Theme Modes","description":"Dark and light presentation tuned for both premium feel and long-session usability.","icon":"T"},{"number":"06","title":"Accessibility QA","description":"Contrast, keyboard, and assistive-support standards baked in from system level upward.","icon":"A"}],"fullBleed":{"label":"Product Launch","quote":"The interface needed to feel proven on day one. That was the design brief in one sentence.","imageIndex":2},"imageStackCaption":"Product stills - launch cycle","imageStackIndex":"01 - 04","processHeading":"How trust became the interface.","photoGridLabel":"Data, product, precision","photoGridNote":"Each image supports the sense of clarity, confidence, and financial fluency behind the product."}}],["$L3","$L4"],"$L5"]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"tm1SaEzyKFRM92keFoSRS"}
